<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<title>Car Dodge - Esquiva los Obstáculos</title>
<style>
    body {
        margin: 0;
        padding: 0;
        background: #000;
        font-family: Arial, sans-serif;
        display: flex;
        justify-content: center;
        align-items: center;
        height: 100vh;
        overflow: hidden;
    }
    canvas {
        image-rendering: pixelated;
        border: 4px solid #333;
    }
    #gameContainer {
        position: relative;
    }
    #score {
        position: absolute;
        top: 15px;
        right: 20px;
        color: white;
        font-size: 24px;
        font-weight: bold;
        text-shadow: 2px 2px 4px black;
        z-index: 10;
    }
    #startScreen, #gameOverScreen {
        position: absolute;
        top: 0; left: 0; right: 0; bottom: 0;
        background: rgba(0,0,0,0.85);
        color: white;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        z-index: 20;
        font-size: 32px;
    }
    button, .pressEnter {
        margin-top: 30px;
        padding: 15px 40px;
        font-size: 24px;
        background: #ffcc00;
        color: black;
        border: none;
        border-radius: 8px;
        cursor: pointer;
    }
</style>
</head>
<body>

<div id="gameContainer">
    <div id="score">Monedas: <span id="coinCount">0</span></div>
    <canvas id="gameCanvas" width="600" height="700"></canvas>
    
    <!-- Pantalla de inicio -->
    <div id="startScreen">
        <h1>🚗 CAR DODGE 🚗</h1>
        <p>Esquiva los obstáculos</p>
        <button onclick="startGame()">JUGAR</button>
        <p style="font-size:18px;margin-top:30px;">← → o A D para moverte</p>
    </div>

    <!-- Pantalla Game Over -->
    <div id="gameOverScreen" style="display:none;">
        <h1 style="color:#ff3333;">GAME OVER</h1>
        <p id="finalScore">Monedas: 0</p>
        <p class="pressEnter">Presiona ENTER para volver a jugar</p>
    </div>
</div>

<script>
// =============== CONFIGURACIÓN ===============
const canvas = document.getElementById('gameCanvas');
const ctx = canvas.getContext('2d');
const WIDTH = canvas.width;
const HEIGHT = canvas.height;

let gameRunning = false;
let score = 0;
let distance = 0;
let speed = 4;
const BASE_SPEED = 4;

// Carriles (4 carriles)
const lanes = [120, 240, 360, 480];
let playerLane = 1; // índice del carril (0-3)

// Jugador
const player = {
    x: lanes[1],
    y: HEIGHT - 140,
    width: 50,
    height: 90,
    lane: 1
};

// Arrays
let obstacles = [];
let coins = [];

// Controles
let keys = {};

// Imágenes simuladas (usamos colores y formas)
function drawCar(x, y, w, h, color, isPlayer = false) {
    ctx.fillStyle = color;
    ctx.fillRect(x, y, w, h);
    
    // Techo
    ctx.fillStyle = isPlayer ? '#00aaff' : '#aa0000';
    ctx.fillRect(x+8, y+15, w-16, 35);
    
    // Luces
    ctx.fillStyle = '#ffff00';
    ctx.fillRect(x+5, y+5, 12, 12);
    ctx.fillRect(x+w-17, y+5, 12, 12);
}

// =============== EVENTOS ===============
window.addEventListener('keydown', e => {
    keys[e.key] = true;
    
    if (!gameRunning && e.key === 'Enter') {
        if (document.getElementById('gameOverScreen').style.display === 'flex') {
            resetGame();
        }
    }
});

window.addEventListener('keyup', e => keys[e.key] = false);

// =============== FUNCIONES DEL JUEGO ===============
function startGame() {
    document.getElementById('startScreen').style.display = 'none';
    resetGame();
}

function resetGame() {
    obstacles = [];
    coins = [];
    score = 0;
    distance = 0;
    speed = BASE_SPEED;
    player.lane = 1;
    player.x = lanes[1];
    
    document.getElementById('gameOverScreen').style.display = 'none';
    gameRunning = true;
    updateScore();
    gameLoop();
}

function updateScore() {
    document.getElementById('coinCount').textContent = score;
}

function spawnObstacle() {
    if (Math.random() < 0.025 + distance/10000) {
        const laneIndex = Math.floor(Math.random() * 4);
        const type = Math.random() > 0.6 ? 'car' : 'moto';
        
        obstacles.push({
            x: lanes[laneIndex],
            y: -100,
            width: type === 'car' ? 55 : 30,
            height: type === 'car' ? 100 : 50,
            color: '#' + Math.floor(Math.random()*16777215).toString(16),
            type: type,
            speed: speed * (0.9 + Math.random()*0.3)
        });
    }
}

function spawnCoin() {
    if (Math.random() < 0.03) {
        const laneIndex = Math.floor(Math.random() * 4);
        coins.push({
            x: lanes[laneIndex] + 15,
            y: -30,
            size: 25,
            collected: false
        });
    }
}

function update() {
    if (!gameRunning) return;
    
    distance += 1;
    
    // Aumentar dificultad
    if (distance % 800 === 0) {
        speed = Math.min(speed + 0.6, 12);
    }
    
    // Movimiento del jugador
    if ((keys['ArrowLeft'] || keys['a'] || keys['A']) && player.lane > 0) {
        player.lane--;
        player.x = lanes[player.lane];
        keys['ArrowLeft'] = keys['a'] = keys['A'] = false; // evitar movimiento continuo
    }
    if ((keys['ArrowRight'] || keys['d'] || keys['D']) && player.lane < 3) {
        player.lane++;
        player.x = lanes[player.lane];
        keys['ArrowRight'] = keys['d'] = keys['D'] = false;
    }
    
    // Actualizar obstáculos
    for (let i = obstacles.length - 1; i >= 0; i--) {
        obstacles[i].y += obstacles[i].speed;
        
        // Colisión
        if (
            player.x < obstacles[i].x + obstacles[i].width &&
            player.x + player.width > obstacles[i].x &&
            player.y < obstacles[i].y + obstacles[i].height &&
            player.y + player.height > obstacles[i].y
        ) {
            gameOver();
            return;
        }
        
        if (obstacles[i].y > HEIGHT) {
            obstacles.splice(i, 1);
        }
    }
    
    // Actualizar monedas
    for (let i = coins.length - 1; i >= 0; i--) {
        coins[i].y += speed;
        
        // Recoger moneda
        if (
            !coins[i].collected &&
            Math.abs(player.x + player.width/2 - coins[i].x) < 40 &&
            Math.abs(player.y + player.height/2 - coins[i].y) < 50
        ) {
            coins[i].collected = true;
            score++;
            updateScore();
        }
        
        if (coins[i].y > HEIGHT + 50) {
            coins.splice(i, 1);
        }
    }
    
    spawnObstacle();
    spawnCoin();
}

function drawRoad() {
    // Fondo carretera
    ctx.fillStyle = '#222222';
    ctx.fillRect(60, 0, WIDTH-120, HEIGHT);
    
    // Bordes
    ctx.fillStyle = '#555';
    ctx.fillRect(50, 0, 20, HEIGHT);
    ctx.fillRect(WIDTH-70, 0, 20, HEIGHT);
    
    // Líneas de carriles
    ctx.strokeStyle = '#ffff00';
    ctx.lineWidth = 6;
    ctx.setLineDash([40, 40]);
    
    for (let i = 1; i < 4; i++) {
        ctx.beginPath();
        ctx.moveTo(lanes[i]-10, 0);
        ctx.lineTo(lanes[i]-10, HEIGHT);
        ctx.stroke();
    }
    ctx.setLineDash([]);
    
    // Líneas laterales
    ctx.strokeStyle = '#ffffff';
    ctx.lineWidth = 8;
    ctx.beginPath();
    ctx.moveTo(80, 0);
    ctx.lineTo(80, HEIGHT);
    ctx.moveTo(WIDTH-80, 0);
    ctx.lineTo(WIDTH-80, HEIGHT);
    ctx.stroke();
}

function draw() {
    ctx.clearRect(0, 0, WIDTH, HEIGHT);
    
    drawRoad();
    
    // Dibujar obstáculos
    for (let obs of obstacles) {
        if (obs.type === 'car') {
            drawCar(obs.x, obs.y, obs.width, obs.height, obs.color);
        } else {
            // Moto
            ctx.fillStyle = obs.color;
            ctx.fillRect(obs.x + 5, obs.y, obs.width-10, obs.height);
            ctx.fillStyle = '#111';
            ctx.fillRect(obs.x + 8, obs.y + 10, obs.width-16, 20);
        }
    }
    
    // Dibujar monedas
    ctx.fillStyle = '#ffdd00';
    for (let coin of coins) {
        if (!coin.collected) {
            ctx.beginPath();
            ctx.arc(coin.x, coin.y, coin.size/2, 0, Math.PI*2);
            ctx.fill();
            ctx.fillStyle = '#ffaa00';
            ctx.font = 'bold 18px Arial';
            ctx.textAlign = 'center';
            ctx.fillText('$', coin.x, coin.y + 7);
            ctx.fillStyle = '#ffdd00';
        }
    }
    
    // Dibujar jugador
    drawCar(player.x, player.y, player.width, player.height, '#00cc00', true);
}

function gameOver() {
    gameRunning = false;
    document.getElementById('finalScore').textContent = `Monedas recolectadas: ${score}`;
    document.getElementById('gameOverScreen').style.display = 'flex';
}

function gameLoop() {
    if (!gameRunning) return;
    
    update();
    draw();
    
    requestAnimationFrame(gameLoop);
}

// Iniciar
document.getElementById('startScreen').style.display = 'flex';
</script>

</body>
</html>

